#!/usr/bin/env bash
# Layer 1/2: Type checking (fast on changed files, <1min full)
# Type checks using pyright (faster than mypy for incremental)

set -euo pipefail

echo "🔎 Type checking with pyright..."

# Check if pyright is available, fallback to mypy
# Try uv run, then venv, then python3 -m, then command
if command -v uv &> /dev/null && uv run pyright --version &>/dev/null 2>&1; then
    TYPE_CMD="uv run pyright"
elif [ -d "venv" ] && source venv/bin/activate && python -m pyright --version &>/dev/null 2>&1; then
    source venv/bin/activate
    TYPE_CMD="python -m pyright"
elif python3 -m pyright --version &>/dev/null 2>&1; then
    TYPE_CMD="python3 -m pyright"
elif command -v pyright &> /dev/null; then
    TYPE_CMD="pyright"
elif command -v uv &> /dev/null && uv run mypy --version &>/dev/null 2>&1; then
    TYPE_CMD="uv run mypy"
elif [ -d "venv" ] && source venv/bin/activate && python -m mypy --version &>/dev/null 2>&1; then
    source venv/bin/activate
    TYPE_CMD="python -m mypy"
elif python3 -m mypy --version &>/dev/null 2>&1; then
    TYPE_CMD="python3 -m mypy"
elif command -v mypy &> /dev/null; then
    TYPE_CMD="mypy"
else
    echo "⚠️  Neither pyright nor mypy found. Skipping type check."
    echo "   Install with: uv sync --dev  or  pip install pyright mypy"
    exit 0
fi

if [ $# -gt 0 ]; then
    # Check only provided files (for pre-commit)
    # Filter out test files
    FILES_TO_CHECK=()
    for file in "$@"; do
        if [[ ! "$file" =~ test_.*\.py$ ]] && [[ ! "$file" =~ /tests/ ]] && [[ ! "$file" =~ tests/ ]]; then
            FILES_TO_CHECK+=("$file")
        fi
    done
    if [ ${#FILES_TO_CHECK[@]} -gt 0 ]; then
        $TYPE_CMD "${FILES_TO_CHECK[@]}"
    else
        echo "⚠️  All provided files are test files. Skipping type check."
        exit 0
    fi
else
    # Full type check (Layer 2) - only check source, not tests
    # Tests often use dicts where typed configs are expected, which is fine
    if echo "$TYPE_CMD" | grep -q pyright; then
        # pyright respects pyrightconfig.json which excludes tests
        # Just check src/ directory - pyrightconfig.json handles exclusions
        $TYPE_CMD src/
    else
        # For mypy, use a config that's more lenient
        $TYPE_CMD src/
    fi
fi

echo "✅ Type checking complete"
